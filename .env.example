# =============================================================================
# the-5-agents - Environment Variables Template
# =============================================================================
# Copy this file to .env and fill in real values.
# .env is gitignored and must NEVER be committed.
# =============================================================================

# --- Anthropic / Claude API ---
# Required if agents call the Claude API directly (outside the Claude Code CLI).
# Get one at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# --- Project metadata ---
PROJECT_NAME=the-5-agents
PROJECT_ENV=development

# =============================================================================
# Add new variables below as the project grows.
# Examples (uncomment and fill when needed):
# OPENAI_API_KEY=
# GOOGLE_API_KEY=
# SERPER_API_KEY=
# =============================================================================
